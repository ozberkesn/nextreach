# PostgreSQL connection string (Neon, Supabase, Render, or local Postgres all work)
DATABASE_URL="postgresql://user:password@localhost:5432/nextreach?schema=public"

# Anthropic API key used by the chatbot, https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# Shared password that protects the /admin view. There is no user/account
# system (out of scope per PRD) -- this is a single shared secret.
ADMIN_SECRET="change-me"
